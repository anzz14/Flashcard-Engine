generator client {
	provider = "prisma-client-js"
}

datasource db {
	provider  = "postgresql"
}

model User {
	id              String    @id @default(cuid())
	email           String    @unique
	name            String?
	emailVerified   DateTime?
	image           String?
	password        String?   // null for OAuth users
	streakCurrent   Int       @default(0)
	streakLongest   Int       @default(0)
	lastStudiedAt   DateTime?
	reminderEnabled Boolean   @default(true)
	createdAt       DateTime  @default(now())

	decks    Deck[]
	reviews  Review[]
	accounts Account[]
	sessions Session[]
}

model Account {
	// Standard NextAuth Account model — all required fields for @auth/prisma-adapter
	id                String  @id @default(cuid())
	userId            String
	type              String
	provider          String
	providerAccountId String
	refresh_token     String? @db.Text
	access_token      String? @db.Text
	expires_at        Int?
	token_type        String?
	scope             String?
	id_token          String? @db.Text
	session_state     String?

	user User @relation(fields: [userId], references: [id], onDelete: Cascade)

	@@unique([provider, providerAccountId])
}

model Session {
	// Standard NextAuth Session model
	id           String   @id @default(cuid())
	sessionToken String   @unique
	userId       String
	expires      DateTime
	user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
	// Standard NextAuth VerificationToken model
	identifier String
	token      String   @unique
	expires    DateTime

	@@unique([identifier, token])
}

model Deck {
	id          String    @id @default(cuid())
	userId      String
	name        String
	archived    Boolean   @default(false)
	createdAt   DateTime  @default(now())
	updatedAt   DateTime  @updatedAt
	lastStudied DateTime?

	user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
	cards         Card[]
	generationJob GenerationJob?

	@@index([userId])
	@@index([userId, archived])
}

model Card {
	id             String    @id @default(cuid())
	deckId         String
	question       String    @db.Text
	answer         String    @db.Text
	topicTag       String?
	interval       Float     @default(1)
	easeFactor     Float     @default(2.5)
	repetitions    Int       @default(0)
	nextReviewDate DateTime  @default(now())
	isNew          Boolean   @default(true)
	createdAt      DateTime  @default(now())
	updatedAt      DateTime  @updatedAt

	deck    Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
	reviews Review[]

	@@index([deckId])
	@@index([deckId, nextReviewDate])
	@@index([deckId, topicTag])
}

model Review {
	id         String       @id @default(cuid())
	cardId     String
	userId     String
	rating     ReviewRating
	reviewedAt DateTime     @default(now())

	card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
	user User @relation(fields: [userId], references: [id], onDelete: Cascade)

	@@index([cardId])
	@@index([userId, reviewedAt])
}

model GenerationJob {
	id           String    @id @default(cuid())
	deckId       String    @unique
	status       JobStatus @default(PENDING)
	totalChunks  Int       @default(0)
	doneChunks   Int       @default(0)
	errorMessage String?
	createdAt    DateTime  @default(now())
	updatedAt    DateTime  @updatedAt

	deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
}

enum ReviewRating {
	AGAIN
	HARD
	GOOD
	EASY
}

enum JobStatus {
	PENDING
	PROCESSING
	DONE
	FAILED
}
